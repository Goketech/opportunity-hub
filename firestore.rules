rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function myUserDoc() {
      return userDoc(request.auth.uid);
    }

    function isStudent() {
      return isSignedIn()
        && userExists(request.auth.uid)
        && myUserDoc().data.role == 'student';
    }

    function isFounder() {
      return isSignedIn()
        && userExists(request.auth.uid)
        && myUserDoc().data.role == 'startup_founder';
    }

    function myStartupId() {
      return myUserDoc().data.startupId;
    }

    function hasStartupLink() {
      return myStartupId() is string && myStartupId().size() > 0;
    }

    function isStartupFounderFor(startupId) {
      return isFounder()
        && hasStartupLink()
        && myStartupId() == startupId;
    }

    function startupDoc(startupId) {
      return get(/databases/$(database)/documents/startups/$(startupId));
    }

    function startupExists(startupId) {
      return exists(/databases/$(database)/documents/startups/$(startupId));
    }

    function isVerifiedStartup(startupId) {
      return startupExists(startupId)
        && startupDoc(startupId).data.isAluVerified == true;
    }

    function opportunityDoc(opportunityId) {
      return get(/databases/$(database)/documents/opportunities/$(opportunityId));
    }

    function hasAllowedUserKeys() {
      return request.resource.data.keys().hasOnly([
        'id',
        'role',
        'fullName',
        'aluEmail',
        'bio',
        'skills',
        'portfolioUrls',
        'avatarUrl',
        'isProfileComplete',
        'startupId',
        'startupVerificationMethod',
        'startupVerificationReference',
        'createdAt',
        'updatedAt',
      ]);
    }

    function hasAllowedStartupKeys() {
      return request.resource.data.keys().hasOnly([
        'id',
        'name',
        'logoUrl',
        'isAluVerified',
        'founderIds',
        'teamSize',
        'description',
        'categories',
        'status',
        'createdAt',
        'updatedAt',
      ]);
    }

    function hasAllowedOpportunityKeys() {
      return request.resource.data.keys().hasOnly([
        'id',
        'startupId',
        'title',
        'category',
        'description',
        'requirements',
        'duration',
        'compensationType',
        'screeningQuestions',
        'isOpen',
        'createdAt',
        'updatedAt',
      ]);
    }

    function hasAllowedApplicationKeys() {
      return request.resource.data.keys().hasOnly([
        'opportunityId',
        'studentId',
        'startupId',
        'answers',
        'status',
        'appliedAt',
        'reviewedAt',
        'reviewNotes',
      ]);
    }

    function isValidApplicationStatus(status) {
      return status in ['submitted', 'reviewed', 'accepted', 'rejected', 'withdrawn'];
    }

    match /users/{uid} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && hasAllowedUserKeys()
        && request.resource.data.id == uid
        && request.resource.data.aluEmail.matches('.*@(alueducation\\.com|alu\\.edu)$');

      allow update: if isOwner(uid)
        && hasAllowedUserKeys()
        && request.resource.data.id == uid
        && request.resource.data.aluEmail == resource.data.aluEmail
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.role == resource.data.role
        && (
          request.resource.data.startupId == resource.data.startupId
          || (
            resource.data.role == 'startup_founder'
            && (
              resource.data.startupId == null
              || resource.data.startupId == ''
            )
            && request.resource.data.startupId is string
            && request.resource.data.startupId.size() > 0
          )
        );

      allow delete: if false;
    }

    match /startup_verification_registry/{token} {
      allow read, write: if false;
    }

    match /startups/{startupId} {
      // Students can only read verified startups.
      // Founders can read their own startup document.
      allow read: if (isStudent() && resource.data.isAluVerified == true)
        || isStartupFounderFor(startupId);

      allow create: if isFounder()
        && !hasStartupLink()
        && hasAllowedStartupKeys()
        && request.resource.data.id == startupId
        && request.resource.data.founderIds.hasOnly([request.auth.uid]);

      allow update: if isStartupFounderFor(startupId)
        && hasAllowedStartupKeys()
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.founderIds == resource.data.founderIds;

      allow delete: if false;
    }

    match /opportunities/{opportunityId} {
      // Student reads are restricted to verified startups only.
      allow read: if (isStudent() && isVerifiedStartup(resource.data.startupId))
        || isStartupFounderFor(resource.data.startupId);

      allow create: if isStartupFounderFor(request.resource.data.startupId)
        && hasAllowedOpportunityKeys()
        && request.resource.data.id == opportunityId;

      allow update: if isStartupFounderFor(resource.data.startupId)
        && hasAllowedOpportunityKeys()
        && request.resource.data.id == resource.data.id
        && request.resource.data.startupId == resource.data.startupId
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isStartupFounderFor(resource.data.startupId);
    }

    match /applications/{applicationId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.studentId
        || isStartupFounderFor(resource.data.startupId)
      );

      // Students can only create their own applications against verified startup opportunities.
      allow create: if isStudent()
        && hasAllowedApplicationKeys()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status == 'submitted'
        && request.resource.data.reviewedAt == null
        && (
          request.resource.data.reviewNotes == null
          || request.resource.data.reviewNotes == ''
        )
        && exists(/databases/$(database)/documents/opportunities/$(request.resource.data.opportunityId))
        && opportunityDoc(request.resource.data.opportunityId).data.startupId == request.resource.data.startupId
        && isVerifiedStartup(request.resource.data.startupId);

      // Founders can review applications only for their startup and cannot mutate ownership fields.
      allow update: if isStartupFounderFor(resource.data.startupId)
        && hasAllowedApplicationKeys()
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.opportunityId == resource.data.opportunityId
        && request.resource.data.startupId == resource.data.startupId
        && request.resource.data.appliedAt == resource.data.appliedAt
        && isValidApplicationStatus(request.resource.data.status);

      allow delete: if false;
    }

    match /startup_metrics/{startupId} {
      // Founder analytics are private to the owning startup.
      allow read: if isStartupFounderFor(startupId);

      // Counter writes are allowed for signed-in clients, but constrained to
      // startupId + updatedAt + single-step increments on tracked counters.
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'startupId',
          'totalViews',
          'totalApplications',
          'updatedAt',
        ])
        && request.resource.data.startupId == startupId
        && request.resource.data.updatedAt == request.time
        && (
          (
            request.resource.data.totalViews == 1
            && (
              !('totalApplications' in request.resource.data)
              || request.resource.data.totalApplications == 0
            )
          )
          ||
          (
            request.resource.data.totalApplications == 1
            && (
              !('totalViews' in request.resource.data)
              || request.resource.data.totalViews == 0
            )
          )
        );

      allow update: if isSignedIn()
        && request.resource.data.startupId == resource.data.startupId
        && request.resource.data.startupId == startupId
        && request.resource.data.updatedAt == request.time
        && request.resource.data.totalViews is int
        && request.resource.data.totalApplications is int
        && (
          (
            request.resource.data.totalViews == resource.data.totalViews + 1
            && request.resource.data.totalApplications == resource.data.totalApplications
          )
          ||
          (
            request.resource.data.totalApplications == resource.data.totalApplications + 1
            && request.resource.data.totalViews == resource.data.totalViews
          )
        );

      allow delete: if false;
    }

    match /opportunity_view_events/{eventId} {
      // Event docs are write-only for clients; analytics should read aggregated metrics.
      allow read: if false;

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'id',
          'startupId',
          'opportunityId',
          'viewerId',
          'viewDateKey',
          'createdAt',
        ])
        && request.resource.data.id == eventId
        && request.resource.data.viewerId == request.auth.uid
        && request.resource.data.viewDateKey.matches('^[0-9]{8}$')
        && exists(/databases/$(database)/documents/opportunities/$(request.resource.data.opportunityId))
        && opportunityDoc(request.resource.data.opportunityId).data.startupId == request.resource.data.startupId
        && isVerifiedStartup(request.resource.data.startupId)
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }
  }
}
